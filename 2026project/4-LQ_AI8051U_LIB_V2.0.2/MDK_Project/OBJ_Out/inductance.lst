    6          /**
    7           * @brief ADC 值归一化
    8           * 将 ADC 值归一化到指定范围
    9           * @param value ADC 值
   10           * @param min 最小值
   11           * @param max 最大值
   12           * @return 归一化后的值
   13           */
   14          int _adcNormalize(int value, double min, double max)
   15          {
   16   1          double normalized = (double)(value - min) / (max - min)* 100.0;
   17   1          if(normalized > 100.0) normalized = 100.0;
   18   1          if(normalized < 1.0) normalized = 1.0;
   19   1          return (int)normalized;
   20   1      }
