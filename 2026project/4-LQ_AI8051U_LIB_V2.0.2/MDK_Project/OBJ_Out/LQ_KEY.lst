   19          /*************************************************************************
   20           *  函数名称：void GPIO_KEY_Init(void)
   21           *  功能说明：GPIO初始化函数
   22           *  参数说明：无
   23           *  函数返回：无
   24           *  修改时间：2020年3月10日
   25           *  备    注：
   26           *************************************************************************/
   27          void GPIO_KEY_Init(void)
   28          {
   29   1        gpio_init_pin(KEY0_PIN, GPIO_Mode_IPU); // 按键0
   30   1        gpio_init_pin(KEY1_PIN, GPIO_Mode_IPU); // 按键1
   31   1        gpio_init_pin(KEY2_PIN, GPIO_Mode_IPU); // 按键2
   32   1        gpio_init_pin(DSW0_PIN, GPIO_Mode_IPU); // 拨码开关0
   33   1        gpio_init_pin(DSW1_PIN, GPIO_Mode_IPU); // 拨码开关1
   34   1      }
   35          
   36          /*************************************************************************
   37           *  函数名称：unsigned char KEY_Read(KEYn_e KEYno)
   38           *  功能说明：读取按键状态
   39           *  参数说明：KEYn_e KEYno按键编号
   40           *  函数返回：按键状态，按下返回1-TRUE，松开返回0
   41           *  修改时间：2025年1月10日
   42           *  备    注：
   43           *************************************************************************/
   44          unsigned char KEY_Read(KEYn_e KEYno)
   45          {
   46   1        if(KEYno == KEY0) return (!gpio_read_pin(KEY0_PIN)); // 母板上按键0
   47   1        if(KEYno == KEY1) return (!gpio_read_pin(KEY1_PIN)); // 母板上按键1
   48   1        if(KEYno == KEY2) return (!gpio_read_pin(KEY2_PIN)); // 母板上按键2
   49   1        if(KEYno == DSW0) return (!gpio_read_pin(DSW0_PIN)); // 母板上拨码开关0
   50   1        if(KEYno == DSW1) return (!gpio_read_pin(DSW1_PIN)); // 母板上拨码开关1
   51   1        if(KEYno == Tubep) return (!gpio_read_pin(Tubep_PIN)); // 母板上干簧管
   52   1        return 0;
   53   1      }
