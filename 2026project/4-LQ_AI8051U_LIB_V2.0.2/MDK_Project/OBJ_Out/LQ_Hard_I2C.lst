  137          /************************************************************
  138           * @Description: 初始化硬件IIC
  139           * @param   type:选择IIC引脚     tepy  SCL  SDA
  140                                          （0：P2.4 P2.3）
  141                                          （1：P1.5 P1.4）
  142                                          （2：         ）
  143                                          （3：P3.2 P3.3）
  144            * @see    void Hard_IIC_Init();
  145            *
  146            * @date  2024-09-15
  147          *************************************************************/
  148          void Hard_IIC_Init(unsigned char type)
  149          {
  150   1          I2C_InitTypeDef I2C_InitStructure;
  151   1          
  152   1          if (type == 0) // 选择SCL:P2.4与SDA:P2.3为IIC引脚
  153   1          {
  154   2              I2C_SW(I2C_P24_P23);                    // 选择管脚 I2C_P23_P24
  155   2              GPIO_Init(GPIO_P2,GPIO_Pin_3 | GPIO_Pin_4,GPIO_Mode_Out_IN);// 将I2C管脚设为准双向口
  156   2          }
  157   1          else if (type == 1) // 选择P1.5与P1.4为IIC引脚
  158   1          {
  159   2              I2C_SW(I2C_P15_P14);
  160   2              GPIO_Init(GPIO_P1,GPIO_Pin_4 | GPIO_Pin_5,GPIO_Mode_Out_IN);
  161   2          }
  162   1      #ifdef STC32G12K_32Bit
                   else if (type == 2)
                   {
                       I2C_SW(I2C_P76_P77); // STC32G支持的管脚        // 8051U仅三组，I2C_S[1:0]  可选值0，1，3 无2
                   }
               #endif
  168   1          else if (type == 3) // 选择P3.2与P3.3为IIC引脚
  169   1          {
  170   2              I2C_SW(I2C_P32_P33); // I2C_P24_P23; I2C_P15_P14; I2C_P32_P33
  171   2              GPIO_Init(GPIO_P3,GPIO_Pin_2 | GPIO_Pin_3,GPIO_Mode_Out_IN);
  172   2          }
  173   1      
  174   1          I2C_InitStructure.I2C_Mode = I2C_Mode_Master; // 主从选择   I2C_Mode_Master, I2C_Mode_Slave
  175   1          I2C_InitStructure.I2C_Enable = ENABLE;        // I2C功能使能,   ENABLE, DISABLE
  176   1          I2C_InitStructure.I2C_MS_WDTA = ENABLE;      // 主机使能自动发送,  ENABLE, DISABLE
  177   1          I2C_InitStructure.I2C_Speed = 31;             // 总线速度=Fosc/2/(Speed*2+4),      0~63
  178   1          I2C_Init(&I2C_InitStructure);
  179   1          NVIC_I2C_Init(I2C_Mode_Master, DISABLE, Priority_0); // 主从模式, I2C_Mode_Master, I2C_Mode_Slave; 中
             -断使能, ENABLE/DISABLE; 优先级(低到高) Priority_0,Priority_1,Priority_2,Priority_3
  180   1      }


