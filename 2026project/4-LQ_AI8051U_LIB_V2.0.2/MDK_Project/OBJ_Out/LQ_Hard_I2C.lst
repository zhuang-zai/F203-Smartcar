   86          //========================================================================
   87          // 函数: void I2C_WriteNbyte(u8 dev_addr, u8 mem_addr, u8 *p, u8 number)
   88          // 描述: I2C写入数据函数.
   89          // 参数: dev_addr: 设备地址, mem_addr: 存储地址, *p写入数据存储位置, number写入数据个数.
   90          // 返回: none.
   91          // 版本: V1.0, 2020-09-15
   92          //========================================================================
   93          void Hard_I2C_WriteNbyte(u8 dev_addr, u8 mem_addr, u8 *p, u8 number)
   94          {
   95   1        Start();      // 发送起始命令
   96   1        SendData(dev_addr); // 发送设备地址+写命令
   97   1        RecvACK();
   98   1        SendData(mem_addr); // 发送存储地址
   99   1        RecvACK();
  100   1        do
  101   1        {
  102   2          SendData(*p++);
  103   2          RecvACK();
  104   2        } while (--number);
  105   1        Stop(); // 发送停止命令
  106   1      }
  107          
