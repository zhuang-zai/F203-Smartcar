  177          double PID_Realize(PID* sptr, double ActualSpeed, double SetSpeed, double *MOTOR_PID)
  178          {
  179   1          double Increase;        // 单次PID输出
  180   1      //    double iTermLimited;    // 限幅后的积分项
  181   1      
  182   1          // 参数赋值
  183   1          sptr->KP = *MOTOR_PID;
  184   1          sptr->KI = *(MOTOR_PID + 1);
  185   1          sptr->KD = *(MOTOR_PID + 2);
  186   1      
  187   1          // 计算当前误差
  188   1          sptr->iError = SetSpeed - ActualSpeed;
  189   1      
C251 COMPILER V5.60.0,  control                                                            23/04/26  21:57:25  PAGE 4   

  190   1          // 积分项限幅：限制 KI * iError 在 [-900, +900]
