  208          void Angle_calculate()  //gz 是int16 有符号整形，范围是-32768 - 32768（开区间） 因此此处是错的
  209          {     
  210   1          Gyroz=(double)gz;
  211   1          if(Gyroz<32768)Gyroz = - (Gyroz / 16.4);
  212   1          if(Gyroz>=32768)Gyroz = + (65535 - Gyroz) / 16.4;
  213   1       
  214   1          Angle_gyro_z += Gyroz * 0.002;  // 根据中断周期进行微调
  215   1      }
  216          /**
  217          * @brief 归一化函数，将输入值映射到 1 ~ 100 范围
  218          * @param value 输入初始电感值（此时为整型）
  219          * @return double 归一化后的值（1 ~ 100）
  220          */
  221          double Adc_Normalize(int value, double min, double max)
  222          {
  223   1          double normalized = 0;
  224   1          // 计算归一化值
  225   1          normalized = (double)(value - min) / (max - min) * 100.0f;
  226   1          // 限幅保护，确保返回值在 1 ~ 100 范围内
  227   1          normalized = range_protect(normalized, 1.0, 100.0);
  228   1          return normalized;
  229   1      }
  230          void Calculate_Differential_Drive() // 差速计算
  231          {
  232   1        float k = 0; // 差速比例系数
  233   1        k = eleout * 0.01; // 将 -100 ~ 100 缩放成 -1 ~ 1
  234   1        k = range_protect(k, -0.65, 0.65); // 限制到 -0.65 ~ 0.65，实现差速限幅
  235   1        // 计算左右轮目标速度
  236   1        if(k < 0) // 左转
  237   1        {
  238   2          k *= -1;
  239   2          Left_High_Speed = High_Speed * (1 - k);
  240   2          Right_High_Speed= High_Speed * (1 + k*0.2); // 加少减多
  241   2        }
  242   1        else // 右转
  243   1        {
  244   2          Left_High_Speed = High_Speed * (1 + k*0.2); // 加少减多
  245   2          Right_High_Speed= High_Speed * (1 - k);
  246   2        }
  247   1      }
