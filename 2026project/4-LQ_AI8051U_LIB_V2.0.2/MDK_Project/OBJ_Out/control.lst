  154          /**
  155           * @brief 位置式 PID（用于转向控制）
  156           */
  157          double PlacePID_Control(PID*sptr, double NowPiont, double SetPoint, double *Turn_PID)
  158          {
  159   1        double Output;  // 本次输出
  160   1        
  161   1        sptr->KP = *Turn_PID;  // 参数赋值
  162   1        sptr->KD = *(Turn_PID+1);
  163   1        
  164   1        sptr->iError = SetPoint - NowPiont;  // 当前误差 = 目标值 - 实际值
  165   1        
  166   1        Output = sptr->KP * sptr->iError  // 比例项
  167   1             + sptr->KD * (sptr->iError - sptr->LastError);  // 微分项
  168   1        
  169   1        sptr->LastError = sptr->iError;  // 更新误差
  170   1        
  171   1        return Output;
  172   1      }
  173          
  174          /**
  175           * @brief 增量式 PID（用于左右轮电机闭环控制）
