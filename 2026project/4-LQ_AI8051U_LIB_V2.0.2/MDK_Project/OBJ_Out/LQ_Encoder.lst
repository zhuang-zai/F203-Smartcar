   18          /**************************************************************************
   19           * 函 数 名：short Read_Encoder(u8 encno)
   20           * 函数功能：单位时间读取编码器计数
   21           * 入口参数：编码器编号  定时器3/4 计数中断管脚唯一固定（STC32G可有两组可选）
   22           * 返 回 值：脉冲数，注意读取之间周期内，不要超过16位最大值
   23           * 调用方式：Enc1 = Read_Encoder(1)；
   24           **************************************************************************/
   25          short Read_Encoder(u8 encno)
   26          {
   27   1        int32 tm=0;
   28   1      
   29   1        if(encno==Enc_1)  //左
   30   1        {
   31   2          tm = T3H;
   32   2          if(P05)             //编码器1计数A:P04  DIR:P05
   33   2            tm=(tm<<8)|T3L;
   34   2          else
   35   2            tm=0-((tm<<8)|T3L);
   36   2      
   37   2          T4T3M &= ~(1<<3);
   38   2          T3H = 0;
   39   2          T3L = 0;
   40   2          T4T3M |= (1<<3);
   41   2          return tm;
   42   2        }
   43   1        else if(encno==Enc_2)  //右
   44   1        {
   45   2          T4T3M &= ~(1<<7);
   46   2          tm = T4H;
   47   2          if(P07)             //编码器２计数A:P06  DIR:P07
   48   2            tm=(tm<<8)|T4L;
   49   2          else
   50   2            tm=0-((tm<<8)|T4L);
   51   2      
   52   2      
   53   2          T4H = 0;
   54   2          T4L = 0;
   55   2          T4T3M |= (1<<7);
   56   2          return tm;
C251 COMPILER V5.60.0,  LQ_Encoder                                                         04/05/26  20:45:36  PAGE 2   

   57   2        }
   58   1        else   return 0;
   59   1      }
   60          
   61          /*************************************************************************
   62          *  函数名称：void Timer_EncInit(u8 tim_x)
   63          *  功能说明：编码器初始化函数
   64          *  参数说明：使用哪个定时器的作为外部技术输入使用
   65          *  函数返回：无
   66          *  修改时间：2024年12月28日
   67          *  备    注：驱动个编码器，注意初始化哪个定时，选择对应的输入管脚
   68          *************************************************************************/
   69          void Timer_EncInit(u8 tim_x)
   70          {
   71   1          if(tim_x == Timer0)
   72   1        {
   73   2              T3L = 0; T3H = 0;
   74   2              T4T3M |= 0x0C;
   75   2          }
   76   1          else if(tim_x == Timer1)
   77   1          {
   78   2              T4L = 0; T4H = 0;
   79   2              T4T3M |= 0xC0;
   80   2          }
   81   1          else if(tim_x == Timer2)  //常被用作串口波特率发生器
   82   1          {
   83   2              T4L = 0; T4H = 0;
   84   2              T4T3M |= 0xC0;
   85   2          }
   86   1          else if(tim_x == Timer3)
   87   1        {
   88   2              T3L = 0; T3H = 0;
   89   2              T4T3M |= 0x0C;
   90   2          }
   91   1          else if(tim_x == Timer4)
   92   1          {
   93   2              T4L = 0; T4H = 0;
   94   2              T4T3M |= 0xC0;
   95   2          }
   96   1          else if(tim_x == (Timer3|Timer4))
   97   1          {
   98   2              T3L = 0; T3H = 0;
   99   2              T4L = 0; T4H = 0;
  100   2              T4T3M |= 0xCC;
  101   2          }
  102   1      
  103   1      //1100 1100 定时器4开始计数  定时器4计数模式  12分频  关闭时钟输出
  104   1      //          定时器3开始计数  定时器3计数模式  12分频  关闭时钟输出
  105   1      
  106   1      }
