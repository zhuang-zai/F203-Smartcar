   60   4                      (*lqbuff) = (*lqbuff) << 1;
   61   4                      Soft_SPI_SCK_L(cfg->sck);                   // 产生一个下降沿
   62   4                      (*lqbuff) |= Soft_SPI_MISO_READ(cfg->miso); // 下降沿采样MISO(CPHA=1)
   63   4                  }
   64   3                  else if (Soft_SPI_Mode_2 == cfg->mode)
   65   3                  {
   66   4                      Soft_SPI_SCK_L(cfg->sck); // 产生一个下降沿
   67   4                      (*lqbuff) = (*lqbuff) << 1;
   68   4                      (*lqbuff) |= Soft_SPI_MISO_READ(cfg->miso); // 下降沿采样MISO(CPHA=0)
   69   4                      Soft_SPI_SCK_H(cfg->sck);                   // 产生一个上升沿
   70   4                  }
   71   3                  else
