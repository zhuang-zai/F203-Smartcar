   32          void soft_spi_read_write_n_byte(const Soft_SPI_cfg_t *cfg, u8 *lqbuff, u16 len)
   33          {
   34   1          u8 i;
   35   1          if ((lqbuff == NULL) || (Soft_SPI_Mode_3 < cfg->mode))
   36   1              return;
   37   1          Soft_SPI_CS_L(cfg->cs); // 拉低片选
   38   1          if ((Soft_SPI_Mode_0 == cfg->mode) || (Soft_SPI_Mode_1 == cfg->mode))
   39   1              Soft_SPI_SCK_L(cfg->sck); // 初始SCK设为低(CPOL=0)
   40   1          else
   41   1              Soft_SPI_SCK_H(cfg->sck); // 初始SCK设为高(CPOL=1)
   42   1          do
   43   1          {
   44   2              for (i = 0; i < 8; i++)
   45   2              {
   46   3                  if ((*lqbuff) >= 0x80)
   47   3                      Soft_SPI_MOSI_H(cfg->mosi);
   48   3                  else
   49   3                      Soft_SPI_MOSI_L(cfg->mosi);
   50   3                  if (Soft_SPI_Mode_0 == cfg->mode)
   51   3                  {
   52   4                      Soft_SPI_SCK_H(cfg->sck); // 产生一个上升沿
   53   4                      (*lqbuff) = (*lqbuff) << 1;
   54   4                      (*lqbuff) |= Soft_SPI_MISO_READ(cfg->miso); // 上升沿采样MISO(CPHA=0)
   55   4                      Soft_SPI_SCK_L(cfg->sck);                   // 产生一个下降沿
   56   4                  }
