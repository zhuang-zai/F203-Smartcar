C251 COMPILER V5.60.0,  LQ_XINT                                                            04/05/26  16:44:45  PAGE 4   

  175   1          if(Priority > Priority_3) return FAIL;
  176   1          //PxЖЫПкЕФжаЖЯгХЯШМЖ
  177   1      
  178   1          if(0 == Priority) PINIPH &= ~(0x01<<GPIO_Px), PINIPL &= ~(0x01<<GPIO_Px);
  179   1          if(1 == Priority) PINIPH &= ~(0x01<<GPIO_Px), PINIPL |=  (0x01<<GPIO_Px);
  180   1        if(2 == Priority) PINIPH |=  (0x01<<GPIO_Px), PINIPL &= ~(0x01<<GPIO_Px);
  181   1        if(3 == Priority) PINIPH |=  (0x01<<GPIO_Px), PINIPL |=  (0x01<<GPIO_Px);
  182   1      
  183   1        return SUCCESS;
  184   1      }
