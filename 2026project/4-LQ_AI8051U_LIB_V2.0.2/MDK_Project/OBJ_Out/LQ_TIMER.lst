   39   2          }
   40   1          else tim_clockT = TIM_CLOCK_1T;
   41   1      
   42   1      
   43   1          freq_ps = (u8)((temp) >> 16);                  //获取8位 分频值
   44   1          Period = (u16)(65535 -(temp / (freq_ps+1)));   //获取16位 装载值
   45   1      
   46   1         {
   47   2          switch(Tim)
   48   2          {
   49   3              TIM_InitTypeDef  TIMx_InitStructure;
   50   3      
   51   3           case Timer0:
