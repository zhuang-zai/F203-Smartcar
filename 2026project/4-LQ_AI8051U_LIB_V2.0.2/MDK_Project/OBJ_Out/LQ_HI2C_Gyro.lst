  167          **************************************************************************/
  168          unsigned char Hard_IIC_Write_MPU_Byte(unsigned char addr,unsigned char reg, unsigned char value)
  169          {
  170   1        Hard_IIC_Start();             //Ц№ЪМаХКХ
  171   1        Hard_IIC_SendData(addr);      //ЗЂЫЭЩшБИЕижЗ
  172   1        Hard_IIC_RecvACK();           //ЕШД§ЛиИД
  173   1        Hard_IIC_SendData(reg);       //ЗЂЫЭМФДцЦїЕижЗ
  174   1        Hard_IIC_RecvACK();           //ЕШД§ЛиИД
  175   1        Hard_IIC_SendData(value);       //ЗЂЫЭМФДцЦїЕижЗ
  176   1        Hard_IIC_RecvACK();           //ЕШД§ЛиИД
  177   1        Hard_IIC_Stop();              //ЭЃжЙаХКХ
  178   1      
  179   1        return 0;
  180   1      }
