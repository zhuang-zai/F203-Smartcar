  120            *
  121            * @param    addr  :ЦїМўЕижЗ
  122            * @param    reg   :МФДцЦїЕижЗ
  123            *
  124            * @return   ЖСШЁЕФжЕ
  125            *
  126            * @note     ЕзВуЧ§ЖЏ вЦжВЪБашвЊаоИФ
  127            *
  128            * @see      Hard_IIC_Read_MPU_Byte(Dev_add,WHO_AM_I);
  129            *
  130            * @date     2019/6/12 аЧЦкШ§
  131          **************************************************************************/
  132          unsigned char Hard_IIC_Read_MPU_Byte(unsigned char addr,unsigned char reg)
  133          {
  134   1        unsigned char res, Read_addr;
  135   1        Read_addr = addr+1;
  136   1        Hard_IIC_Start();             //Ц№ЪМаХКХ
  137   1        Hard_IIC_SendData(addr);      //ЗЂЫЭЩшБИЕижЗ
  138   1        Hard_IIC_RecvACK();           //ЕШД§ЛиИД
  139   1        Hard_IIC_SendData(reg);       //ЗЂЫЭМФДцЦїЕижЗ
  140   1        Hard_IIC_RecvACK();           //ЕШД§ЛиИД
  141   1      
  142   1        Hard_IIC_Start();             //ЗЂЫЭЦ№ЪМаХКХ
  143   1        Hard_IIC_SendData(Read_addr); //ЗЂЫЭЩшБИЕижЗ+1 ЃЈЮЊЖСШЁИУЕижЗЕФаХКХЃЉ
  144   1        res = Hard_IIC_RecvData();    //ЖСШЁЪ§Он
  145   1        Hard_IIC_SendNAK();           //ЗДРЁаХКХ
  146   1        Hard_IIC_Stop();              //ЭЃжЙаХКХ
  147   1      
  148   1        return res;
  149   1      }
