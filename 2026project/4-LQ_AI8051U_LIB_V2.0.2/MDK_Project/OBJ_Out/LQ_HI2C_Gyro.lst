   57            * @note     ЪЙгУЧАЯШГѕЪМЛЏIICНгПк
   58            * @see      MPU6050_Init();
   59            * @date     2019/6/12 аЧЦкШ§
   60            *************************************************************************/
   61          unsigned char Gyro_Init(void)
   62          {
   63   1        unsigned char res;
   64   1        unsigned char  dat, Accel_Fsr = 1, Gyro_Fsr = 3;
   65   1        int rate = 1000;
   66   1        switch(dev_Name)
   67   1        {
   68   2          case ICM42605:
   69   2              {
   70   3                  OLED_P8x16Str(0,3,"ICM42605 NO CARE");
   71   3      //            while(1);
   72   3              }break;
   73   2          case MPU9250:
   74   2              {
   75   3                  Hard_IIC_Write_MPU_Byte(Dev_add,MPU_FIFO_EN_REG,0X00);  //ЙиБеFIFO
   76   3                  Hard_IIC_Write_MPU_Byte(Dev_add,MPU_INTBP_CFG_REG,0X82);//INTв§НХЕЭЕчЦНгааЇЃЌПЊЦєbypassФЃЪН
   77   3                  res = Hard_IIC_Read_MPU_Byte(AK8963_ADDR,MPU_MAG_WIA);   //ЖСШЁMPU9250ЕФID
   78   3                  if(res == AK8963_ID)                                //ЦїМўIDе§ШЗ
   79   3                  {
   80   4                      Hard_IIC_Write_MPU_Byte(AK8963_ADDR,MPU_MAG_CNTL2_REG,0X01);//ШэМўжижУ
   81   4                      delay_ms(100);
   82   4                      Hard_IIC_Write_MPU_Byte(AK8963_ADDR,MPU_MAG_CNTL1_REG,0X16);//ЩшжУЮЊЕЅДЮФЃЪНЃЌЪфГі16bit
   83   4                  }
   84   3              }break;
   85   2          case ICM20602:
   86   2              {}break;
   87   2          case ICM20689:
   88   2              {}break;
   89   2          case MPU6050:
   90   2              {
   91   3                  res = 0;
   92   3                  res += Hard_IIC_Write_MPU_Byte(Dev_add,MPU_PWR_MGMT1_REG,0X80);//ИДЮЛMPU6050
   93   3                  delay_ms(100);  //бгЪБ100ms
   94   3                  res += Hard_IIC_Write_MPU_Byte(Dev_add,MPU_PWR_MGMT1_REG,0X00);//ЛНабMPU6050
   95   3                  res += Hard_IIC_Write_MPU_Byte(Dev_add,MPU_GYRO_CFG_REG,Gyro_Fsr<<3);                      //ЭгТнв
             -ЧДЋИаЦї,ЁР2000dps
   96   3                  res += Hard_IIC_Write_MPU_Byte(Dev_add,MPU_ACCEL_CFG_REG,Accel_Fsr<<3);                    //МгЫй
             -ЖШДЋИаЦї,ЁР4g
   97   3                  if(rate>1000) rate = 1000;
   98   3                  if(rate<4) rate=4;
   99   3                  dat = 1000/rate-1;
  100   3                  res += Hard_IIC_Write_MPU_Byte(Dev_add,MPU_SAMPLE_RATE_REG,dat);      //ЩшжУЪ§зжЕЭЭЈТЫВЈЦї  Щш
             -жУВЩбљТЪ1000Hz
  101   3                  res += Hard_IIC_Write_MPU_Byte(Dev_add,MPU_CFG_REG,0x02);      //ЩшжУЪ§зжЕЭЭЈТЫВЈЦї   98hz
  102   3                  res += Hard_IIC_Write_MPU_Byte(Dev_add,MPU_INT_EN_REG,0X00);   //ЙиБеЫљгажаЖЯ
  103   3                  res += Hard_IIC_Write_MPU_Byte(Dev_add,MPU_USER_CTRL_REG,0X00);//I2CжїФЃЪНЙиБе
  104   3                  res += Hard_IIC_Write_MPU_Byte(Dev_add,MPU_PWR_MGMT1_REG,0X01);//ЩшжУCLKSEL,PLL XжсЮЊВЮПМ
  105   3                  res += Hard_IIC_Write_MPU_Byte(Dev_add,MPU_PWR_MGMT2_REG,0X00);//МгЫйЖШгыЭгТнвЧЖМЙЄзї
  106   3      
  107   3              }break;
  108   2              case errorid: break;
  109   2      
  110   2        }
  111   1        return 0;
  112   1      }
