   34          unsigned char Get_Slave_ID(void)
   35          {
   36   1        unsigned char ID;
   37   1      
   38   1        //ЖСШЁЩшБИIDЃЌЫљгаЭгТнвЧЕФIDЖМЪЧ0xD0,ВЂЧвДцЗХIDЕФМФДцЦїЖМЪЧ0X7F
   39   1        ID = Hard_IIC_Read_MPU_Byte(Dev_add,WHO_AM_I);
   40   1        switch(ID)
   41   1        {
   42   2          case 0x09:dev_Name = ICM20602;break;
   43   2          case 0x38:dev_Name = MPU9250 ;break;
   44   2          case 0x4C:dev_Name = ICM20689;break;
   45   2          case 0x21:dev_Name = ICM42605;break;
   46   2          case 0x34:dev_Name = MPU6050 ;break;
   47   2          default :dev_Name = errorid ;return 0;
   48   2        }
   49   1        return ID;
   50   1      }
