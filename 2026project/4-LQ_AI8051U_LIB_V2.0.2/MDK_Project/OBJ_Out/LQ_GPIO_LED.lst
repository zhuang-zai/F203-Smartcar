   17          /*************************************************************************
   18           * @code    void GPIO_LED_Init(void);
   19           * @brief   痰빵딧痰 LED놓迦뺏넋埼. LED0 -->瞳LQ_BEEP_LED.h櫓브땍屢
   20           * @return  none.
   21           * @date    2025-10-22.
   22           *************************************************************************/
   23          void GPIO_LED_Init(void)
   24          {
   25   1        gpio_init_pin(LED_0P, GPIO_Mode_Out_PP); // LED0 股共渴놔
   26   1        gpio_init_pin(LED_1P, GPIO_Mode_Out_PP); // LED1
   27   1        gpio_init_pin(LED_2P, GPIO_Mode_Out_PP); // LED2
   28   1      
   29   1        gpio_write_pin(LED_0P, HIGH); // 놓迦뺏밑균LED0 윗멕
   30   1        gpio_write_pin(LED_1P, HIGH); // 밑균LED1
   31   1        gpio_write_pin(LED_2P, HIGH); // 밑균LED2
   32   1      }
   33          
   34          
   35          /*************************************************************************
   36           * @code    void LED_Ctrl(LED_n ledp, LED_s sta)
   37           * @brief   痰빵딧痰 LED榴檄왠齡넋埼.
   38           * @param   ledp ：LED긍뵀， LED0/LED1/LED2/LED_ALL
   39           * @param   sta  ：LED榴檄， ON/ OFF/ RVS
   40           * @return  none.
   41           * @date    2025-10-22.
   42           * @note    LED밗신瞳 庫匡숭櫓브땍屢，侶쟁殮쌈賈痰눈固51돨貫꾸鱗槻쪽뫘멕
   43           *************************************************************************/
   44          void LED_Ctrl(LED_n ledp, LED_s sta)
   45          {
   46   1        switch (ledp)
   47   1        {
   48   2        case LED0:
   49   2          if (sta == ON)      LED_PIN0 = LOW;
   50   2          else if (sta == OFF)  LED_PIN0 = HIGH;
   51   2          else if (sta == RVS)  LED_PIN0 = !LED_PIN0;
   52   2          break;
   53   2          case LED1:
   54   2          if (sta == ON)      LED_PIN1 = LOW;
   55   2          else if (sta == OFF)  LED_PIN1 = HIGH;
   56   2          else if (sta == RVS)  LED_PIN1 = !LED_PIN1;
   57   2          break;
C251 COMPILER V5.60.0,  LQ_GPIO_LED                                                        16/04/26  19:10:15  PAGE 2   

   58   2        case LED2:
   59   2          if (sta == ON)      LED_PIN2 = LOW;
   60   2          else if (sta == OFF)  LED_PIN2 = HIGH;
   61   2          else if (sta == RVS)  LED_PIN2 = !LED_PIN2;
   62   2          break;
   63   2        case LED_ALL:
   64   2          if (sta == ON)
   65   2          {
   66   3            LED_PIN0 = LOW;   LED_PIN1 = LOW;   LED_PIN2 = LOW;
   67   3          }
   68   2          else if (sta == OFF)
   69   2          {
   70   3            LED_PIN0 = HIGH;   LED_PIN1 = HIGH;   LED_PIN2 = HIGH;
   71   3          }
   72   2          else if (sta == RVS)
   73   2          {
   74   3            LED_PIN0 = !LED_PIN0; LED_PIN1 = !LED_PIN1; LED_PIN2 = !LED_PIN2;
   75   3          }
   76   2          break;
   77   2        default:;
   78   2          break;
   79   2        }
