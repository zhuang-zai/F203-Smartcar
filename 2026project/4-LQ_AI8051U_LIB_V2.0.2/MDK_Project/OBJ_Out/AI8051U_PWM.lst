  329          //========================================================================
  330          // КЏЪ§: ReadPWMA(void)
  331          // УшЪі: вьВНЖСШЁPWMAЬиЪтЙІФмМФДцЦїКЏЪ§.
  332          // ВЮЪ§: addr: ЖСШЁЬиЪтЙІФмМФДцЦїЕижЗ.
  333          // ЗЕЛи: dat:  ЖСШЁЬиЪтЙІФмМФДцЦїФкШн.
  334          // АцБО: V1.0, 2022-03-16
  335          //========================================================================
  336          u8 ReadPWMA(u8 addr)
  337          {
  338   1        u8 dat;
  339   1      
  340   1        while (HSPWMA_ADR & 0x80)
  341   1          ;           // ЕШД§ЧАвЛИівьВНЖСаДЭъГЩ
  342   1        HSPWMA_ADR = addr | 0x80; // ЩшжУМфНгЗУЮЪЕижЗ,жЛашвЊЩшжУд­XFRЕижЗЕФЕЭ7ЮЛ
  343   1                      // HSPWMA_ADDRМФДцЦїЕФзюИпЮЛаД1,БэЪОЖСЪ§Он
  344   1        while (HSPWMA_ADR & 0x80)
  345   1          ;       // ЕШД§ЕБЧАвьВНЖСШЁЭъГЩ
  346   1        dat = HSPWMA_DAT; // ЖСШЁвьВНЪ§Он
  347   1      
  348   1        return dat;
  349   1      }
