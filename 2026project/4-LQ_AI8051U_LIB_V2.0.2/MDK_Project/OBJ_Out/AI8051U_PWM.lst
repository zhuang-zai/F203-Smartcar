  266          void UpdatePwm(u8 PWM, PWMx_Duty *PWMx)
  267          {
  268   1        switch (PWM)
  269   1        {
  270   2        case PWM1:    PWMA_Duty1(PWMx->PWM1_Duty);    break;
  271   2        case PWM2:    PWMA_Duty2(PWMx->PWM2_Duty);    break;
  272   2        case PWM3:    PWMA_Duty3(PWMx->PWM3_Duty);    break;
  273   2        case PWM4:    PWMA_Duty4(PWMx->PWM4_Duty);    break;
  274   2        case PWM5:    PWMB_Duty5(PWMx->PWM5_Duty);    break;
  275   2        case PWM6:    PWMB_Duty6(PWMx->PWM6_Duty);    break;
  276   2        case PWM7:    PWMB_Duty7(PWMx->PWM7_Duty);    break;
  277   2        case PWM8:    PWMB_Duty8(PWMx->PWM8_Duty);    break;
  278   2        case PWMA:
  279   2          PWMA_Duty1(PWMx->PWM1_Duty);
  280   2          PWMA_Duty2(PWMx->PWM2_Duty);
  281   2          PWMA_Duty3(PWMx->PWM3_Duty);
