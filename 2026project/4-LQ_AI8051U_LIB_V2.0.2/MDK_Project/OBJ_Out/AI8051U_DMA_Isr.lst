                 if(DMA_SPI_STA & 0x01)  //通信完成
                 {
                   DMA_SPI_STA &= ~0x01; //清标志位
                   if(MSTR)
                   { //主机模式
                     SpiTxFlag = 1;
                     SPI_SS_2 = 1;
                   }
                   else
                   { //从机模式
                     SpiRxFlag = 1;
                   }
                 }
                 if(DMA_SPI_STA & 0x02)  //数据丢弃
                 {
                   DMA_SPI_STA &= ~0x02; //清标志位
                 }
                 if(DMA_SPI_STA & 0x04)  //数据覆盖
                 {
                   DMA_SPI_STA &= ~0x04; //清标志位
                 }
               
                 //------------- LCM --------------
                 if(LCMIFSTA & 0x01)
                 {
                   LCMIFSTA = 0x00;
C251 COMPILER V5.60.0,  AI8051U_DMA_Isr                                                    04/05/26  16:38:05  PAGE 9   

                   LcmFlag = 0;
                 }
               
                 //---------- DMA LCM -------------
                 if(DMA_LCM_STA & 0x01)
                 {
                   if(DmaLcmFlag)
                   {
                     DmaLcmFlag = 0;
                     DMA_LCM_CR = 0;
                   }
                   else
                   {
                     LCM_Cnt--;
                     if(LCM_Cnt == 0)
                     {
                       DMA_LCM_CR = 0;
                       LCD_CS=1;
                     }
                     else
                     {
                       DMA_LCM_CR = 0xa0;  //Write dat
                     }
                   }
                   DMA_LCM_STA = 0;    //清标志位
                 }
               #endif
