   20          /**
   21           * @brief 计算循迹偏差
   22           * 使用差比和算法计算车辆偏离中心线的程度
   23           * 公式：( (左感+左感) - (右感+右感) ) / (总电感 + 补偿值) * 100
   24           * @return int 归一化后的偏差值，范围 -100 到 100
   25           */
   26          int Calculate_Deviation(void) 
   27          {
   28   1          // 获取电感ADC数组指针 (假设顺序为: 左外, 左内, 中, 右内, 右外)
   29   1          int* adc_values = GetInductance();
   30   1          
   31   1          // 计算左右两侧电感值的差值 (分子)，反映偏向哪一侧
   32   1          int eleSub = (adc_values[0] + adc_values[1]) - (adc_values[3] + adc_values[4]);
   33   1          
   34   1          // 计算所有电感值的总和 (分母)，+10是为了防止分母为0导致除零错误
   35   1          // 使用“差比和”可以消除由于速度变化导致的磁场强度整体变化影响
   36   1          int eleAdd = adc_values[0] + adc_values[1] + adc_values[2] + adc_values[3] + adc_values[4] + 10;
   37   1          
   38   1          // 计算归一化偏差值
   39   1          float eleValue = (float)eleSub / (float)eleAdd * 100.0f;
   40   1          
   41   1          // 限幅处理：将偏差值限制在 -100 到 100 之间
   42   1          if(eleValue > 100.0f) eleValue = 100.0f;
   43   1          else if(eleValue < -100.0f) eleValue = -100.0f;
   44   1      
   45   1          // 转换为整型返回给控制层
   46   1          return (int)eleValue;
   47   1      }
   48          
