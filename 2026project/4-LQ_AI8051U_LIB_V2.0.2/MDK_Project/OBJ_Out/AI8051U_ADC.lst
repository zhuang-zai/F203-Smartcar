    8          /***********************************************************************************
    9           * 函 数 名：void ADC_GPIO_Init(ADC_CHx CHn_IOx)
   10           * 功    能：ADC管脚初始化,模拟输入模式,高阻浮空
   11           * 参    数：无
   12           * 返 回 值：无
   13           * 说    明：    //ADC 端口IO配置，详见ADC_CHx
   14           *          eg:ADC_GPIO_Init(ADC_CH0_P10); //配置ADC0输入端为P10口
   15           **********************************************************************************/
   16          void ADC_GPIO_Init(ADC_CHx CHn_IOx)
   17          {
   18   1          if (CHn_IOx < ADC_CH0_P10 || CHn_IOx > ADC_CH15_P07)        return; // 输入参数错误
   19   1          if (CHn_IOx <= ADC_CH7_P17)
   20   1          {
   21   2              GPIO_Init(GPIO_P1, ((u8)(1 << CHn_IOx)), GPIO_Mode_IN_FLOATING);     // 模拟输入模式,高阻浮空
   22   2          }
   23   1          else if (CHn_IOx <= ADC_CH15_P07)
   24   1          {
   25   2              GPIO_Init(GPIO_P0, ((u8)(1 << (CHn_IOx - 8))), GPIO_Mode_IN_FLOATING); // 模拟输入模式,高阻浮空
   26   2          }
   27   1      }
   28          //========================================================================
   29          // 函数: u8 ADC_Inilize(ADC_InitTypeDef *ADCx)
   30          // 描述: ADC初始化程序.
   31          // 参数: ADCx: 结构参数,请参考adc.h里的定义.
   32          // 返回: none.
   33          // 版本: V1.0, 2012-10-22
   34          //========================================================================
   35          u8 ADC_Inilize(ADC_InitTypeDef *ADCx)
   36          {
   37   1        ADCCFG = (ADCCFG & ~ADC_SPEED_2X16T) | ADCx->ADC_Speed; // 设置ADC工作时钟频率
   38   1        ADC_Justify(ADCx->ADC_AdjResult);           // AD转换结果对齐方式
   39   1      
   40   1        if (ADCx->ADC_SMPduty > 31)
   41   1          return FAIL; // 错误
   42   1        if (ADCx->ADC_CsSetup > 1)
   43   1          return FAIL; // 错误
   44   1        if (ADCx->ADC_CsHold > 3)
   45   1          return FAIL; // 错误
   46   1      
   47   1        ADCTIM = (ADCx->ADC_CsSetup << 7) | (ADCx->ADC_CsHold << 5) | ADCx->ADC_SMPduty; // 设置 ADC 内部时序，A
             -DC采样时间建议设最大值
   48   1        return SUCCESS;
   49   1      }
