   66          //========================================================================
   67          // 函数: u16 Get_ADCResult(ADC_CHx channel)
   68          // 描述: 查询法读一次ADC转换结果.
   69          // 参数: channel: 选择要转换的ADC通道.0-15
   70          // 返回: ADC转换结果.
   71          // 版本: V1.0, 2012-10-22
   72          //========================================================================
   73          u16 Get_ADCResult(ADC_CHx channel)
   74          {
   75   1        u16 adc;
   76   1        u8 i;
   77   1      
   78   1        if (channel > ADC_CH15_P07)
   79   1          return 4096; // 错误,返回4096,调用的程序判断
   80   1        ADC_RES = 0;
   81   1        ADC_RESL = 0;
   82   1      
   83   1        ADC_CONTR = (ADC_CONTR & 0xf0) | channel; // 设置ADC转换通道
   84   1        ADC_START = 1;                // 启动ADC转换
   85   1        NOP(10);                  // 对ADC_CONTR操作后要4T之后才能访问
   86   1      
   87   1        for (i = 0; i < 250; i++) // 超时返回，正常i等于10以内就可以转换完成
   88   1        {
   89   2          if (ADC_FLAG)
   90   2          {
   91   3            ADC_FLAG = 0; // 清除ADC转换结束标志
   92   3            if (RESFMT)   // 转换结果右对齐。
   93   3            {
   94   4              adc = ((u16)ADC_RES << 8) | ADC_RESL;
   95   4            }
   96   3            else // 转换结果左对齐。
   97   3            {
   98   4              adc = (u16)ADC_RES;
   99   4              adc = (adc << 4) | ((ADC_RESL >> 4) & 0x0f);
  100   4            }
  101   3            return adc;
  102   3          }
  103   2        }
  104   1        return 4096; // 错误,返回4096,调用的程序判断
  105   1      }


