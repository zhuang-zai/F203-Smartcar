   46          /*************************************************************************
   47           *  函数名称：u8 Get_ADC_Key()
   48           *  功能说明：传入ADC 按键通道的ADC值，返回ADC按键键值
   49           *  参数说明：u16 key_ADval：ADC值
   50           *  函数返回：ADC按键的键值
   51           *  修改时间：2026年1月12日
   52           *  备    注：无
   53           *************************************************************************/
C251 COMPILER V5.60.0,  LQ_ADC_KEY                                                         16/04/26  19:10:16  PAGE 2   

   54          u8 Get_ADC_Key()
   55          {
   56   1          u16 key_ADval = Get_ADCResult(ADC_CH10_P02); // Get_DmaAD_val();
   57   1          // 根据ADC值范围判断按键,粗略计算
   58   1          // if(key_ADval < 500)        return KEY_PRESS;     // K0≈0
   59   1          // else if(key_ADval < 1500) return KEY_UP;        // Ku≈1028
   60   1          // else if(key_ADval < 2700) return KEY_RIGHT;     // Kr≈2345
   61   1          // else if(key_ADval < 3400) return KEY_DOWN;      // Kd≈3110
   62   1          // else if(key_ADval < 3900) return KEY_LEFT;      // Kl≈3630
   63   1      
   64   1          if (key_ADval < 3850 && key_ADval > 3500)        return KEY_LEFT;  // Kl≈3630
   65   1          else if (key_ADval < 3400 && key_ADval > 2900)   return KEY_DOWN;  // Kd≈3110
   66   1          else if (key_ADval < 2700 && key_ADval > 2000)   return KEY_RIGHT; // Kr≈2345
   67   1          else if (key_ADval < 1500 && key_ADval > 800)    return KEY_UP;    // Ku≈1028
   68   1          else if (key_ADval < 500)                        return KEY_PRESS; // K0≈0
   69   1          else                                             return KEY_NONE;  // 无按键≈4096
   70   1      }
   71          
   72          /*************************************************************************
   73           *  函数名称：u8 ADKey_Scan_Task(void)
   74           *  功能说明：ADC按键扫描任务函数
   75           *  参数说明：无
   76           *  函数返回：按键状态
   77           *  修改时间：2026年1月10日
   78           *  备    注：建议用户将本函数放到定时器中断或主循环定时运行，
   79           *  如果循环时间不足，可以直接使用 Get_ADC_Key(); // 得到ADC对应的键值
   80           *************************************************************************/
   81          u8 ADKey_Scan(void)
   82          {
   83   1          static u8 last_key = KEY_NONE;
   84   1          static u8 stable_count = 0;
   85   1      
   86   1          u8 current_key = Get_ADC_Key(); // 得到ADC对应的键值
   87   1          if (current_key == last_key)
   88   1          {
   89   2              stable_count++;
   90   2              if (stable_count >= 3)
   91   2              { // 连续3次检测相同认为稳定
   92   3                  stable_count = 0;
   93   3                  return current_key;
   94   3              }
   95   2          }
   96   1          else
   97   1          {
   98   2              stable_count = 0;
   99   2              last_key = current_key;
  100   2          }
  101   1      
  102   1          return KEY_NONE;
  103   1      }
