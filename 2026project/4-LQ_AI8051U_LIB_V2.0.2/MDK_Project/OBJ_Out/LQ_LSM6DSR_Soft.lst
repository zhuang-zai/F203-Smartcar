  122          /*************************************************************************
  123           * @code    void lsm6dsr_init(void)
  124           * @brief   初始化 LSM6DSR 六轴传感器
  125           * @param   none.
  126           * @return  none.
  127           * @date    2025-12-28.
  128           * @example lsm6dsr_init();
  129           *************************************************************************/
  130          void lsm6dsr_init(void)
  131          {
  132   1      #if defined(LSM6DSR_USE_SOFT_I2C)
  133   1          gpio_init_pin(LSM6DSR_AD0_PIN, GPIO_Mode_Out_PP);    // 设置AD0引脚为推挽输出
  134   1          gpio_write_pin(LSM6DSR_AD0_PIN, LOW);                // 设置AD0引脚为低电平,则LSM6DSR的I2C地址为0x6A
  135   1          lsm6dsr_i2c_cfg.scl  = LSM6DSR_I2C_SCL;              // 设置I2C的SCL引脚
  136   1          lsm6dsr_i2c_cfg.sda  = LSM6DSR_I2C_SDA;              // 设置I2C的SDA引脚
  137   1          lsm6dsr_i2c_cfg.addr = LSM6DSR_ADDR;                 // 设置I2C的地址
  138   1          soft_i2c_init(&lsm6dsr_i2c_cfg);
  139   1      #elif defined(LSM6DSR_USE_SOFT_SPI)
                   lsm6dsr_spi_cfg.sck  = LSM6DSR_SPI_SCK;
                   lsm6dsr_spi_cfg.miso = LSM6DSR_SPI_MISO;
                   lsm6dsr_spi_cfg.mosi = LSM6DSR_SPI_MOSI;
                   lsm6dsr_spi_cfg.cs   = LSM6DSR_SPI_CS;
                   lsm6dsr_spi_cfg.mode = Soft_SPI_Mode_3;
                   soft_spi_init(&lsm6dsr_spi_cfg);
               
               #endif
  148   1          delay_ms(50);      // 延时100ms
  149   1      
  150   1          lsm6dsr_write_reg(LSM6DSR_CTRL1_XL , 0x21);         // 加速度计52Hz(倾斜角检测功能在26Hz,因此加速度计
             -必须设置为>=26Hz), 2g量程
  151   1          lsm6dsr_write_reg(LSM6DSR_CTRL9_XL , 0x38);         // 使能加速度计x, y, z轴
  152   1          lsm6dsr_write_reg(LSM6DSR_CTRL6_C  , 0X40|0x10);    // 陀螺仪电平触发，加速度计高性能使能
  153   1          lsm6dsr_write_reg(LSM6DSR_CTRL7_G  , 0X80);         // 陀螺仪高性能使能
  154   1          lsm6dsr_write_reg(LSM6DSR_INT2_CTRL, 0X03);         // 加速度计INT2引脚失能,陀螺仪数据INT2使能
  155   1          lsm6dsr_write_reg(LSM6DSR_CTRL2_G  , 0X1C);         // 陀螺仪12.5hz  2000dps
  156   1          lsm6dsr_write_reg(LSM6DSR_CTRL10_C , 0X38);         // 使能陀螺仪x,y,z轴
  157   1          delay_ms(10);
  158   1          lsm6dsr_write_reg(LSM6DSR_FUNC_CFG, 0x00);
  159   1      }
  160          
  161          /*************************************************************************
  162           * @code    void lsm6dsr_read_raw_data(int16 *ax, int16 *ay, int16 *az, int16 *gx, int16 *gy, int16 *gz)
  163           * @brief   读取 LSM6DSR 的六轴原始数据
  164           * @param   ax : 存放 x 轴加速度数据的指针.
  165           * @param   ay : 存放 y 轴加速度数据的指针.
  166           * @param   az : 存放 z 轴加速度数据的指针.
  167           * @param   gx : 存放 x 轴陀螺仪数据的指针.
  168           * @param   gy : 存放 y 轴陀螺仪数据的指针.
  169           * @param   gz : 存放 z 轴陀螺仪数据的指针.
  170           * @return  none.
  171           * @date    2025-12-28.
  172           * @example lsm6dsr_read_raw_data(&ax, &ay, &az, &gx, &gy, &gz);
  173           *************************************************************************/
  174          void lsm6dsr_read_raw_data(int16 *ax, int16 *ay, int16 *az, int16 *gx, int16 *gy, int16 *gz)
  175          {
  176   1          u8 buf[12] = {0};
  177   1          lsm6dsr_read_n_reg(LSM6DSR_OUTX_L_GYRO, buf, 12);
  178   1          *gx = ((u16)buf[1]  << 8) | buf[0];
  179   1          *gy = ((u16)buf[3]  << 8) | buf[2];
  180   1          *gz = ((u16)buf[5]  << 8) | buf[4];
  181   1          *ax = ((u16)buf[7]  << 8) | buf[6];
  182   1          *ay = ((u16)buf[9]  << 8) | buf[8];
  183   1          *az = ((u16)buf[11] << 8) | buf[10];
C251 COMPILER V5.60.0,  LQ_LSM6DSR_Soft                                                    04/05/26  16:44:46  PAGE 4   

  184   1      }
