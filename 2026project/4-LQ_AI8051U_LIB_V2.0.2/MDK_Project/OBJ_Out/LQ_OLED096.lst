   26          void OLED_Init(void)
   27          {
   28   1          gpio_init_pin(OLED_CLK_PIN, GPIO_Mode_Out_PP);
   29   1          gpio_init_pin(OLED_RST_PIN, GPIO_Mode_Out_PP);
