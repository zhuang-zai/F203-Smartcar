   31   1          gpio_init_pin(OLED_DC_PIN, GPIO_Mode_Out_PP);
   32   1          gpio_init_pin(OLED_CS_PIN, GPIO_Mode_Out_PP);
   33   1      
   34   1          OLED_CK_H;
   35   1          OLED_CS_H;  //ФӨЦЖSLKәНSSОӘёЯөзЖҪ
   36   1        OLED_RST_L;
   37   1          delay_ms(50);
   38   1          OLED_RST_H;
   39   1      
   40   1          OLED_WrCmd(0xae);//--turn off oled panel  №ШұХOLEDГж°е
   41   1          OLED_WrCmd(0x00);//---set low column address  ЙиЦГөНБРөШЦ·
   42   1          OLED_WrCmd(0x10);//---set high column address  ЙиЦГёЯБРөШЦ·
   43   1          OLED_WrCmd(0x40);//--set start line address  Set Mapping RAM Display Start Line (0x00~0x3F)  ЙиЦГҝӘКј
             -РРөШЦ· јҜУіЙд RAM ПФКҫҝӘКјРР
   44   1          OLED_WrCmd(0x81);//--set contrast control register  ЙиЦГ¶ФұИ¶ИҝШЦЖјДҙжЖч
   45   1          OLED_WrCmd(0xcf); // Set SEG Output Current Brightness  ЙиЦГ SEG КдіцөзБчББ¶И
   46   1          OLED_WrCmd(0xa1);//--Set SEG/Column Mapping     0xa0ЧуУТ·ҙЦГ 0xa1ХэіЈ
   47   1          OLED_WrCmd(0xc8);//Set COM/Row Scan Direction   0xc0ЙППВ·ҙЦГ 0xc8ХэіЈ
   48   1          OLED_WrCmd(0xa6);//--set normal display  ЙиЦГХэіЈПФКҫ
   49   1          OLED_WrCmd(0xa8);//--set multiplex ratio(1 to 64)  ЙиЦГ¶аВ·ёҙУГұИ
   50   1          OLED_WrCmd(0x3f);//--1/64 duty
   51   1          OLED_WrCmd(0xd3);//-set display offset  Shift Mapping RAM Counter (0x00~0x3F)  ЙиЦГПФКҫЖ«ТЖУіЙд RAM јЖ
             -КэЖч
   52   1          OLED_WrCmd(0x00);//-not offset  І»Ж«ТЖ
   53   1          OLED_WrCmd(0xd5);//--set display clock divide ratio/oscillator frequency  ЙиЦГПФКҫКұЦУіэ·ЁұИ/ХсөҙЖчЖө
             -ВК
