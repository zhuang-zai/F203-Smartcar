  197           * @example gpio_init_pin(P2_0, GPIO_Mode_Out_PP); // 初始化 P2_0 管脚为推挽输出
  198           *************************************************************************/
  199          void gpio_init_pin(Pin_list Pin_x, GPIO_Mode mode)
  200          {
  201   1          switch (mode)
  202   1          {
  203   2              case GPIO_Mode_Out_IN:
  204   2              GPIO_Set_Out_IN(Pin_x);
  205   2            break;
  206   2              case GPIO_Mode_IN_FLOATING:
  207   2                  GPIO_Set_IN_FLOATING(Pin_x); /* 浮空输入 高阻态 无上下拉*/
  208   2                  break;
  209   2              case GPIO_Mode_IPU:
  210   2                  GPIO_Set_IN_FLOATING(Pin_x); /* 先设置为浮空输入 再使能上拉 */
  211   2                  gpio_pull_up(Pin_x, ENABLE);
  212   2                  break;
  213   2              case GPIO_Mode_IPD:
  214   2                  GPIO_Set_IN_FLOATING(Pin_x); /* 先设置为浮空输入 再使能下拉 */
  215   2                  gpio_pull_down(Pin_x, ENABLE);
  216   2                  break;
  217   2              case GPIO_Mode_Out_PP:
  218   2                  GPIO_Set_Out_PP(Pin_x);     /* 推挽输出，驱动能力用户选择是否强驱动和IO速度 */
  219   2                  break;
  220   2              case GPIO_Mode_Out_OD:
  221   2                  GPIO_Set_Out_OD(Pin_x);    /* 通用开漏模式，开漏即可读取外部状态 也可对外输出高低电平 */
  222   2                  break;
  223   2          default:  break;
  224   2          }
  225   1      }
