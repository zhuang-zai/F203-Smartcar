    7          //========================================================================
    8          // 函数: SPI_ISR_Handler
    9          // 描述: SPI中断函数.
   10          // 参数: none.
   11          // 返回: none.
   12          // 版本: V1.0, 2020-09-23
   13          //========================================================================
   14          void SPI_ISR_Handler() interrupt SPI_VECTOR
   15          {
   16   1          if(SPIF)
   17   1          {
   18   2              if(MSTR)  //主机模式
   19   2              {
   20   3                  B_SPI_Busy = 0;
   21   3              }
   22   2              else        //从机模式
   23   2              {
   24   3                  if(SPI_RxCnt >= SPI_BUF_LENTH) SPI_RxCnt = 0;
   25   3                  SPI_RxBuffer[SPI_RxCnt++] = SPDAT;
   26   3              }
   27   2          }
   28   1          SPI_ClearFlag();      //清 SPIF 和 WCOL 标志
   29   1      
   30   1          if(SPITOSR & 0x01)
   31   1          {
   32   2              SPI_RxTimerOut = 1;
   33   2              SPI_TOIFClear();     //设置 CTOCF 清除超时标志位 TOIF
   34   2          }
   35   1      }


