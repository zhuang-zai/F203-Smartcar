               #else
  145   1      
  146   1          for(i=0;i<8;i++)
  147   1          {
  148   2              IPS_CK_L;                   // SCK=0
  149   2              if(cmd&0x80)
  150   2                  {
  151   3                      IPS_DI_H;               // SDI=1
  152   3                  }else{
  153   3                      IPS_DI_L;               // SDI=0
  154   3                  }
  155   2              IPS_CK_H;                   // SCK=1
  156   2              cmd <<= 1;
  157   2          }
  158   1      #endif
  159   1          IPS_DC_H;
  160   1      }
