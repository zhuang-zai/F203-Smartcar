  180   2              if(dat&0x80){IPS_DI_H;}// SDI=1
  181   2              else{IPS_DI_L;}// SDI=0
  182   2              IPS_CK_H;   // SCK=1 ILI9163_SCK = 1;
  183   2              dat = (dat<<1);
