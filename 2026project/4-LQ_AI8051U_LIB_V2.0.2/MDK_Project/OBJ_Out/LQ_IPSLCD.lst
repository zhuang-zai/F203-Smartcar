  138          void LCD_Write_Cmd(unsigned char cmd)
  139          {
  140   1          unsigned char i;
  141   1          IPS_DC_L;// A0=0 ILI9163_A0=0;     //A0=0ЗЂЫЭУќСю
  142   1      #if Use_HARDSPI
