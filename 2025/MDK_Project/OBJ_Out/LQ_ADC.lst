   19          /***********************************************************************************
   20           * 函 数 名：void ADC_Init(void)
   21           * 功    能：ADC初始化，管脚初始化和中断模式、使能等设置
   22           * 参    数：无
   23           * 返 回 值：无
   24           * 说    明：
   25           **********************************************************************************/
   26          void ADC_Init(void)
   27          {
   28   1        ADC_InitTypeDef   ADC_InitStructure;    //结构定义
   29   1      
   30   1          //ADC 端口IO配置，这里将支持ADC的端口全部配置了，实际请仅初始化需要的管脚
   31   1          P0_MODE_IN_HIZ(GPIO_Pin_0);
   32   1          P1_MODE_IN_HIZ(GPIO_Pin_0|GPIO_Pin_1|GPIO_Pin_2|GPIO_Pin_3|GPIO_Pin_4|GPIO_Pin_5);    //或 GPIO_InitC
             -onfig(P1_0|P1_1|P1_2|P1_3|P1_4|P1_5,OUT_IN);
   33   1      
   34   1          //ADC配置
   35   1        ADC_InitStructure.ADC_SMPduty   = 31;   //ADC 模拟信号采样时间控制, 0~31（注意： SMPDUTY 一定不能设置小于
             - 10）
   36   1        ADC_InitStructure.ADC_CsSetup   = 0;    //ADC 通道选择时间控制 0(默认),1
   37   1        ADC_InitStructure.ADC_CsHold    = 1;    //ADC 通道选择保持时间控制 0,1(默认),2,3
   38   1        ADC_InitStructure.ADC_Speed     = ADC_SPEED_2X16T;    //设置 ADC 工作时钟频率 ADC_SPEED_2X1T~ADC_SPEED_2X1
             -6T
   39   1        ADC_InitStructure.ADC_AdjResult = ADC_RIGHT_JUSTIFIED;  //ADC结果调整,  ADC_LEFT_JUSTIFIED,ADC_RIGHT_JUSTI
             -FIED
   40   1        ADC_Inilize(&ADC_InitStructure);    //初始化
   41   1        ADC_PowerControl(ENABLE);       //ADC电源开关, ENABLE或DISABLE
   42   1        NVIC_ADC_Init(DISABLE,Priority_0);    //中断使能, ENABLE/DISABLE; 优先级(低到高) Priority_0,Priority_1,Pri
             -ority_2,Priority_3
   43   1      
   44   1      }
