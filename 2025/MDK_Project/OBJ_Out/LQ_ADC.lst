   61   2              sprintf(txt, "AD3:%05d ", Get_ADCResult(1));  //ADC3-P11
   62   2              OLED_P6x8Str(10,4, txt);  // 显示
   63   2              sprintf(txt, "AD5:%05d ", Get_ADCResult(2));  //ADC5-P12
   64   2              OLED_P6x8Str(10,5, txt);  // 显示
   65   2              sprintf(txt, "AD7:%05d ", Get_ADCResult(3));  //ADC7-P13
   66   2              OLED_P6x8Str(10,6, txt);  // 显示
   67   2              sprintf(txt, "AD5:%05d ", Get_ADCResult(4));  //ADC5-P14
