   46          void Test_ADC()
   47          {
   48   1        char txt[20];
   49   1        ADC_Init();
   50   1        OLED_Init();                    //OLED初始化
   51   1        OLED_CLS();     //加入OLED显示
   52   1        OLED_P6x8Str(10, 0, "LQ ADC_TEST");
