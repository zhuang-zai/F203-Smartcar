   56   1        {
   57   2              sprintf(txt, "ADV:%05d ", Get_ADCResult(8));  //ADC8-P00做电源电压 11.0V->1700左右，12.6V->1970左
             -右
   58   2              OLED_P6x8Str(10,2, txt);  // 显示
   59   2              sprintf(txt, "AD1:%05d ", Get_ADCResult(0));  //ADC1-P10
