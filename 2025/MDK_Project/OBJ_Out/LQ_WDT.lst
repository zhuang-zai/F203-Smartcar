   36           *      WDT_SCALE_128,     6         дМ1.115 s
   37           *      WDT_SCALE_256      7         дМ2.229 s
   38           ***************************************************************************************/
   39          void WDT_Init(WDT_PS_SCALE WDT_SCALE_s)
   40          {
   41   1        WDT_InitTypeDef WDT_InitStructure;          //ПДУХЙЗ НсЙЙЖЈвх
   42   1      
   43   1        WDT_InitStructure.WDT_Enable     = ENABLE;      //жаЖЯЪЙФм   ENABLEЛђDISABLE
   44   1        WDT_InitStructure.WDT_IDLE_Mode  = WDT_IDLE_STOP; //IDLEФЃЪНЪЧЗёЭЃжЙМЦЪ§    WDT_IDLE_STOP,WDT_IDLE_RUN
   45   1        WDT_InitStructure.WDT_PS         = WDT_SCALE_s;     //ПДУХЙЗЖЈЪБЦїЪБжгЗжЦЕЯЕЪ§ 0~7
   46   1        WDT_Inilize(&WDT_InitStructure);          //ГѕЪМЛЏ
   47   1      
   48   1        RSTFLAG |= 0x04;   //ИДЮЛМФДцЦїRSTFLAGЃЌЩшжУПДУХЙЗИДЮЛашвЊМьВтP3.2ЕФзДЬЌЃЌЗёдђПДУХЙЗИДЮЛКѓПЩФмНјШыUSBЯТд
             -иФЃЪН
