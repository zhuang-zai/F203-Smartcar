   56          unsigned char KEY_Read(KEYn_e KEYno)
   57          {
C251 COMPILER V5.60.0,  LQ_KEY                                                             18/03/26  16:19:19  PAGE 2   

   58   1        switch(KEYno)                           //按键
   59   1        {
   60   2          case KEY0:  return KEY0p;       //母板上按键0
   61   2                  break;
   62   2          case KEY1:  return KEY1p;       //母板上按键1
   63   2            break;
   64   2          case KEY2:  return KEY2p;           //母板上按键2
   65   2            break;
   66   2      
   67   2          case DSW0:  return DSW0p;       //母板上拨码开关0
   68   2            break;
   69   2          case DSW1:  return DSW1p;       //母板上拨码开关1
   70   2            break;
   71   2      
   72   2          case Reed_Tube:  return Reed_Tubep; //母板上干簧管
   73   2            break;
   74   2          default:
   75   2                  return 0xFF;
   76   2          }
   77   1          return 0;
   78   1      }
