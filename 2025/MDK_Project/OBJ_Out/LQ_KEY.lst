   80          /*************************************************************************
   81          *  函数名称：unsigned char KEY_Read_All(void)
   82          *  功能说明：读取全部按键状态
   83          *  参数说明：无
   84          *  函数返回：按键组合状态，0--7八种状态
   85          *  修改时间：2022年3月8日
   86          *  备    注：读取三个按键状态，方便组合键使用
   87          *************************************************************************/
   88          unsigned char KEY_Read_All(void)
   89          {
   90   1        unsigned char tm=0;
   91   1        unsigned char k0, k1, k2;
   92   1        k0 = KEY0p;   //获取引脚状态
   93   1        k1 = KEY1p;
   94   1        k2 = KEY2p;
   95   1        tm = k0 | (k1<<1) | (k2 << 2);//读取各个按键状态并编码
   96   1        if(tm==0x07)    //没有按键按下0111
   97   1        {
   98   2          return 0;
   99   2        }
  100   1        return  (~tm)&0X07;
  101   1      }
