   47          /**************************************************************************************
   48           * 函数：LED_Ctrl
   49           * 描述：控制LED状态
   50           * 参数：ledp:定义的LED管脚sta:状态 ON打开 OFF关闭 RVS反转
   51           * 返回：无
   52           * 时间：2024-11-01
   53           * 方法：LED_Ctrl(LED0,ON);
   54           * 备注：LED管脚在 头文件中宏定义
   55           **************************************************************************************/
   56          void LED_Ctrl(LED_n ledp, LED_s sta)
   57          {
C251 COMPILER V5.60.0,  LQ_GPIO_LED                                                        18/03/26  16:19:18  PAGE 2   

   58   1        switch (ledp)
   59   1        {
   60   2        case LED0:
   61   2          if (sta == ON)        LED0p = RESET;
   62   2          else if (sta == OFF)    LED0p = SET;
   63   2          else if (sta == RVS)     LED0p =!LED0p;//(LED0p)?(LED0p=RESET):(LED0p=SET);
   64   2          break;
   65   2        case Beep0:
   66   2          if (sta == ON)      Beep = RESET;
   67   2          else if (sta == OFF)  Beep = SET;
   68   2          else if (sta == RVS)  Beep =!Beep;    //(LED1p)?(LED1p=RESET):(LED1p=SET);
   69   2          break;
   70   2        default:;
   71   2              break;
   72   2        }
   73   1      }
