  434          // 函数：动态权重，分配水平循迹和竖直循迹占比
  435          double Calculate_Weight_Mid(double M)
  436          {
  437   1          double k = 0;
  438   1       
  439   1          if(M >= 1400)  // M >= 80，权重为 100%
  440   1          {
  441   2              k = 100.0;
  442   2          }
  443   1          else if (M >= 400&& M < 1400)  // 线性权重
  444   1          {
  445   2              k = 0.1*M -60;  // y=kx+b：根据 (800,0) 和 (2200,100) 解二元一次方程组
  446   2          }
  447   1          else  // M < 40，权重为 0%
  448   1          {
  449   2              k = 0.0;
  450   2          }
  451   1          
  452   1          k *= 0.01;  // 将范围控制在：0.0 ~ 1.0
  453   1          return k >= 1.0 ? 1.0 : (k <= 0.0 ? 0.0 : k);  // 将 k 限幅保护在 0.0 ~ 1.0 之间
C251 COMPILER V5.60.0,  control                                                            28/03/26  21:02:38  PAGE 8   

  454   1      }
