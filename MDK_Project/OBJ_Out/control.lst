  329   1        
  330   1        // A：人为给定占空比，用于测试：①左右轮不要搞反  ②正反转不要搞反
  331   1      //  LEFT_MOTOR_Duty = 2000;   // 2000 效果：左轮正转，速度较快
  332   1      //  RIGHT_MOTOR_Duty = -1200; //  -1200 效果：右轮反转，速度较慢
  333   1        
  334   1        // B：闭环计算占空比，在确认编码器和电机对应无误后，可实现闭环
  335   1        LEFT_MOTOR_Duty += PID_Realize(&Left_MOTOR_PID, encoder_L, Left_High_Speed, Left_MOTOR);
  336   1        RIGHT_MOTOR_Duty += PID_Realize(&Right_MOTOR_PID, encoder_R, Right_High_Speed, Right_MOTOR);
  337   1      
  338   1      
