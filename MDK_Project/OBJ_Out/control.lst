  492          /**
  493           * 中位值平均滤波函数
  494           * @param arr 输入数据数组
  495           * @param times 数据采样次数
  496           * @return 滤波后的平均值
  497           */
  498          int Median_Average_Filter(int* arr, int times)
  499          {
  500   1          int min = arr[0], max = arr[0], sum = 0;
  501   1          int i = 0;
  502   1          
  503   1          // 遍历数组，找出最大值、最小值并求和
  504   1          for (i = 0; i < times; i++)
  505   1          {
  506   2              if (arr[i] < min) min = arr[i];
  507   2              if (arr[i] > max) max = arr[i];
  508   2              sum += arr[i];
  509   2          }
  510   1       
  511   1          // 计算去掉最大值和最小值后的平均值
  512   1          return (sum - min - max) / (times - 2);
  513   1      }
