  537          double angle_pid(double target, double current)
  538          {
  539   1          double outputa=0;
  540   1          double last_error = 0.0f;
  541   1          double integral = 0.0f;
  542   1          double derivative;
  543   1          double error = 0.0;
  544   1          error = target - current;
  545   1          integral += error;
  546   1      
  547   1          derivative = error - last_error;
  548   1         outputa = kp * error + ki * integral + kd * derivative;
  549   1      
  550   1          // 限幅处理
  551   1          if (outputa > 80) outputa = 80;
  552   1          else if (outputa < -80) outputa = -80;
  553   1      
  554   1          last_error = error;
  555   1          return outputa;
  556   1      }
