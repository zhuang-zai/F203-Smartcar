  397          
  398          /**
  399           * @brief 增量式 PID（用于左右轮电机闭环控制）
  400           */
  401          double PID_Realize(PID* sptr, double ActualSpeed, double SetSpeed, double *MOTOR_PID)
  402          {
  403   1          double Increase;        // 单次PID输出
  404   1          double iTermLimited;    // 限幅后的积分项
  405   1      
  406   1          // 参数赋值
  407   1          sptr->KP = *MOTOR_PID;
  408   1          sptr->KI = *(MOTOR_PID + 1);
  409   1          sptr->KD = *(MOTOR_PID + 2);
  410   1      
  411   1          // 计算当前误差
  412   1          sptr->iError = SetSpeed - ActualSpeed;
  413   1      
  414   1          // 积分项限幅：限制 KI * iError 在 [-900, +900]
  415   1          iTermLimited = sptr->KI * sptr->iError;
  416   1          if (iTermLimited > 1000) iTermLimited = 1000;
  417   1          else if (iTermLimited < -1000) iTermLimited = -1000;
  418   1      
  419   1          // PID增量计算
  420   1          Increase = sptr->KP * (sptr->iError - sptr->LastError)
  421   1                   + iTermLimited
  422   1                   + sptr->KD * (sptr->iError - 2 * sptr->LastError + sptr->PrevError);
  423   1      
  424   1          // 更新误差
  425   1          sptr->PrevError = sptr->LastError;
  426   1          sptr->LastError = sptr->iError;
  427   1      
  428   1          return Increase;
  429   1      }
