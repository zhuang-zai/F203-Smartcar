  376          /**
  377           * @brief 位置式 PID（用于转向控制）
  378           */
  379          double PlacePID_Control(PID*sptr, double NowPiont, double SetPoint, double *Turn_PID)
  380          {
  381   1        double Output;  // 本次输出
  382   1        
  383   1        sptr->KP = *Turn_PID;  // 参数赋值
  384   1        sptr->KD = *(Turn_PID+1);
  385   1        
  386   1        sptr->iError = SetPoint - NowPiont;  // 当前误差 = 目标值 - 实际值
  387   1        
C251 COMPILER V5.60.0,  control                                                            28/03/26  21:02:38  PAGE 7   

  388   1        Output = sptr->KP * sptr->iError  // 比例项
  389   1             + sptr->KD * (sptr->iError - sptr->LastError)  // 微分项
  390   1            ;
  391   1        
  392   1        sptr->LastError = sptr->iError;  // 更新误差
  393   1        
  394   1        return Output;
  395   1      }
