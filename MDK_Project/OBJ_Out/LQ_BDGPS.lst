   25          double my_strtod(const char *str)
   26          {
   27   1        double result = 0.0;
   28   1        double fraction = 1.0;
   29   1      //  int sign = 1;
   30   1      //  int exponent = 0;
   31   1      //  int exp_sign = 1;
   32   1      //  int exp_num = 0;
   33   1      
   34   1        signed char sign = 1;
   35   1        signed char exponent = 0;
   36   1        signed char exp_sign = 1;
   37   1        signed char exp_num = 0;
   38   1          
   39   1        while (isspace(*str)) str++;  // и·іиҝҮз©әзҷҪеӯ—з¬Ұ
   40   1      
   41   1        // еӨ„зҗҶжӯЈиҙҹеҸ·
   42   1        if (*str == '-' || *str == '+')
   43   1        {
   44   2          sign = (*str++ == '-' ? -1 : 1);
   45   2        }
   46   1      
   47   1        // и§Јжһҗж•ҙж•°йғЁеҲҶ
   48   1        while (isdigit(*str))
   49   1        {
   50   2          result = result * 10 + (*str++ - '0');
   51   2        }
   52   1      
   53   1        // еӨ„зҗҶе°Ҹж•°зӮ№
   54   1        if (*str == '.')
   55   1        {
   56   2          str++;
   57   2          while (isdigit(*str))
C251 COMPILER V5.60.0,  LQ_BDGPS                                                           18/03/26  16:19:18  PAGE 2   

   58   2          {
   59   3            fraction /= 10;
   60   3            result += (*str++ - '0') * fraction;
   61   3          }
   62   2        }
   63   1      
   64   1        // еӨ„зҗҶжҢҮж•°йғЁеҲҶ
   65   1        if (*str == 'e' || *str == 'E')
   66   1        {
   67   2          str++;
   68   2          // еӨ„зҗҶжҢҮж•°зҡ„жӯЈиҙҹеҸ·
   69   2          if (*str == '-' || *str == '+')
   70   2          {
   71   3            exp_sign = (*str++ == '-' ? -1 : 1);
   72   3          }
   73   2          exp_num = 0;
   74   2          while (isdigit(*str))
   75   2          {
   76   3            exp_num = exp_num * 10 + (*str++ - '0');
   77   3          }
   78   2          exponent = exp_sign * exp_num;
   79   2        }
   80   1      
   81   1        while (exponent > 0)
   82   1        {
   83   2          result *= 10;
   84   2          exponent--;
   85   2        }
   86   1        while (exponent < 0)
   87   1        {
   88   2          result /= 10;
   89   2          exponent++;
   90   2        }
   91   1      
   92   1        return sign * result;
   93   1      }
