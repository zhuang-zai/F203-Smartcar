  182   1          SPI_Write_reg(0x14, 0x4c);
  183   1          while((SPI_Read_reg(0x22) & 0x01) == 0)  //此处做检查是否读动作完成
  184   1          {
  185   2              if(1000 < count++){
C251 COMPILER V5.60.0,  LQ_LSM6DSR                                                         18/03/26  16:19:19  PAGE 4   

  186   3                  break;
  187   3              }
  188   2              delay_us(100);
  189   2          }
  190   1          return SPI_Read_reg(0x02);  //6DSR的缓冲数据区地址，用于存放挂载的3轴地磁
  191   1      }
