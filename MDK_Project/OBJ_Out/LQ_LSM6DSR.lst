   26          
   27          void LQ_IIC_LSM60DSR_Init(void)
   28          {
   29   1         //加速度计52HZ（倾斜角检测功能工作在26HZ，因此加速度计ODR必须设置为>=26hz）,2g量程。
   30   1         IIC_WriteByteToSlave(LSM6DSR_ADDR,LSM6DSR_CTRL1_XL,0X20);
   31   1         //使能加速度计x,y,z轴
   32   1         IIC_WriteByteToSlave(LSM6DSR_ADDR,LSM6DSR_CTRL9_XL,0X38);
   33   1         //陀螺仪电平触发，加速度计高性能使能
   34   1         IIC_WriteByteToSlave(LSM6DSR_ADDR,LSM6DSR_CTRL6_C,0X40|0x10);
   35   1         //陀螺仪高性能使能
   36   1         IIC_WriteByteToSlave(LSM6DSR_ADDR,LSM6DSR_CTRL7_G,0X80);
   37   1         //加速度计INT2引脚失能,陀螺仪数据INT2使能
   38   1         IIC_WriteByteToSlave(LSM6DSR_ADDR,LSM6DSR_INT2_CTRL,0X03);
   39   1         //陀螺仪12.5hz  2000dps
   40   1         IIC_WriteByteToSlave(LSM6DSR_ADDR,LSM6DSR_CTRL2_G,0X1C);
   41   1         //使能陀螺仪x,y,z轴
   42   1         IIC_WriteByteToSlave(LSM6DSR_ADDR,LSM6DSR_CTRL10_C,0X38);
   43   1      }
   44          
   45          void LQ_IIC_LSM60DSR_Read(signed short *ax,signed short *ay,signed short *az,signed short *gx,signed shor
             -t *gy,signed short *gz)
   46          {
   47   1         unsigned char buf[12];
   48   1         IIC_ReadMultByteFromSlave(LSM6DSR_ADDR, LSM6DSR_OUTX_L_GYRO, 12, buf);
   49   1         *gx=((uint16)buf[1]<<8)|buf[0];
   50   1         *gy=((uint16)buf[3]<<8)|buf[2];
   51   1         *gz=((uint16)buf[5]<<8)|buf[4];
   52   1         *ax=((uint16)buf[7]<<8)|buf[6];
   53   1         *ay=((uint16)buf[9]<<8)|buf[8];
   54   1         *az=((uint16)buf[11]<<8)|buf[10];
   55   1      }
