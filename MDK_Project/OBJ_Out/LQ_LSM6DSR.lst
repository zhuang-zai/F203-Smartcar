  155          //9轴陀螺仪地磁计的寄存器写数据
  156          uint8_t SPI_Mag_Write_Reg(uint8_t addr, uint8_t dat)
  157          {
  158   1          uint32_t count = 0;
  159   1          SPI_Write_reg(0x17, 0x00);
  160   1          SPI_Write_reg(0x15, 0x38);
  161   1          SPI_Write_reg(0x16, addr);
  162   1          SPI_Write_reg(0x21, dat);
  163   1          SPI_Write_reg(0x14, 0x4c);
  164   1          
  165   1          while((SPI_Read_reg(0x22) & 0x80) == 0) //此处做检查是否写动作完成
  166   1          {
  167   2              if(1000 < count++){
  168   3                  return 1;
  169   3              }
  170   2              delay_us(100);
  171   2          }
  172   1          return 0;
  173   1      }
  174          
  175          //从9轴陀螺仪地磁计的寄存器读数据
