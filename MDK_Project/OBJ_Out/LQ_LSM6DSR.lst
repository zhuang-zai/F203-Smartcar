  193          //6轴陀螺仪LSM6DSR和九轴陀螺仪LQ9AGMV的检测
  194          uint8_t Gyro_LSM6DSR_LQ9AGMV_Check(void)
  195          {
  196   1          uint8_t res,i;
  197   1          SPI_Write_reg(LSM6DSR_FUNC_CFG, 0x00);      //切换LSM6D寄存器来连接挂载的3轴地磁 
  198   1          res = LQ_SPI_LSM60DSR_GetID(WHO_AM_LSM6D);
  199   1          
  200   1          if(res == DRV_ID_LSM6D)
  201   1          {
  202   2              for(i = 0;i <= 3; i++)
  203   2              {
  204   3                  SPI_Write_reg(0x14, 0x80);
  205   3                  delay_ms(5);
  206   3                  SPI_Write_reg(0x14, 0x00);
  207   3                  delay_ms(5);
  208   3                  SPI_Write_reg(LSM6DSR_CTRL1_XL,0X20);
  209   3                  SPI_Write_reg(LSM6DSR_FUNC_CFG, 0x40);      //切换到挂载总线读取3轴地磁
  210   3                  if(SPI_Mag_Read_Reg(0x0f) == Mag_ID)
  211   3                  {
  212   4                      res = Mag_ID;           //若能读到3轴地磁ID，则为9AGM，否则可视为6轴的LSM6D
  213   4                      LSM60D_9AGM_FLAG = 1;   //标志1，为9轴模式
  214   4                      break;                  //读到后，退出循环
  215   4                  }
  216   3              }
  217   2              SPI_Write_reg(LSM6DSR_FUNC_CFG, 0x00);
  218   2          }
  219   1          return res;
  220   1      }
