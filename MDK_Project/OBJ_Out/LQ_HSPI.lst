   53          /**************************************************************
   54           *  函数名：void SPI_Write_Nbytes(u32 addr, u8 *buffer, u8 size)
   55           *  功  能：向设备某地址写数据
C251 COMPILER V5.60.0,  LQ_HSPI                                                            18/03/26  16:19:18  PAGE 2   

   56           *  入参数:
   57           *  addr   : 地址参数
   58           *  buffer : 缓冲需要写入设备的数据
   59           *  size   : 数据块大小
   60           *出参数: 无
   61           *************************************************************/
   62          void SPI_Write_NByte(unsigned char addr, unsigned char* buffer, unsigned char sizel)
   63          {
   64   1          SPI_SS_3  = 0;                       // enable device
   65   1          SPI_WriteByte(addr);                //发送写命令设置起始地址
   66   1          do{
   67   2              SPI_WriteByte(*buffer++);       //
   68   2              buffer++;
   69   2          }while(--sizel);
   70   1          SPI_SS_3  = 1;                        // disable device
   71   1      }
   72          
   73          /**************************************************************
   74           *  函数名：void SPI_Write_Nbytes(u32 addr, u8 *buffer, u8 size)写数据到设备中
   75           *  功  能：从设备某地址读取数据
   76           *  入参数:
   77           *  addr   : 地址参数
   78           *  buffer : 缓冲需要读取设备的数据
   79           *  size   : 数据块大小
   80           *出参数: 无
   81           *************************************************************/
   82          void SPI_Read_NByte(unsigned char addr, unsigned char* buffer, unsigned int sizel)
   83          {
   84   1          SPI_SS_3  = 0;                        //enable device
   85   1          SPI_WriteByte(addr);                 //发送读命令
   86   1          do{
   87   2              *buffer = SPI_ReadByte();       //receive byte and store at buffer
   88   2              buffer++;
   89   2          }while(--sizel);                     //read until no_bytes is reached
   90   1          SPI_SS_3  = 1;                        //disable device
   91   1      }


