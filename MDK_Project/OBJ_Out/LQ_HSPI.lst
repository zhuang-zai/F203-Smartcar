   18          /***************************************************************
   19           *  函数名：void HSPI_Init()
   20           *  功  能：硬件SPI应用初始化
   21           *  参  数：无
   22           *  返回值：无
   23           *  说  明：这里初始化的模式是对应SPI接口 陀螺仪的 ，其他SPI使用注意重新初始化
   24           *          同时注意，修改对应使用的SPI管脚 和初始化参数
   25           **************************************************************/
   26          void HSPI_Init()
   27          {
   28   1          GPIO_InitTypeDef    SPI_GPIO_InitStr;
   29   1          SPI_InitTypeDef   SPI_InitStructure;
   30   1          
   31   1          SPI_SW(SPI_P40_P41_P42_P43);          // SPI管脚选择，按组
   32   1          SPI_SS_3 = 1;                           //对应上面选择的管脚，同步修改
   33   1          SPI_IOSW_Enable();                      //交换MMSI和MISO脚位
   34   1          
   35   1           //初始化串口使用收发管脚，需要与实际选择的串口保持一致
   36   1          SPI_GPIO_InitStr.Pin  = GPIO_Pin_0|GPIO_Pin_1|GPIO_Pin_2|GPIO_Pin_3;      //指定要初始化的SPI管脚
   37   1          SPI_GPIO_InitStr.Mode = GPIO_PullUp;                  //指定IO的输入或输出方式,GPIO_PullUp 准双向口
   38   1          GPIO_Inilize(GPIO_P4,&SPI_GPIO_InitStr);              //初始化，结构体配置
   39   1      
   40   1        SPI_InitStructure.SPI_Mode      = SPI_Mode_Master;    //主从选择   SPI_Mode_Master, SPI_Mode_Slave
   41   1        SPI_InitStructure.SPI_CPOL      = SPI_CPOL_Low;     //时钟相位   SPI_CPOL_High,   SPI_CPOL_Low
   42   1        SPI_InitStructure.SPI_CPHA      = SPI_CPHA_1Edge;   //数据边沿   SPI_CPHA_1Edge,  SPI_CPHA_2Edge
   43   1        SPI_InitStructure.SPI_FirstBit  = SPI_MSB;        //移位方向   SPI_MSB, SPI_LSB
   44   1        SPI_InitStructure.SPI_Speed     = SPI_Speed_4;      //SPI速度    SPI_Speed_4, SPI_Speed_8, SPI_Speed_16, SP
             -I_Speed_2
   45   1        SPI_InitStructure.SPI_SSIG      = DISABLE;        //片选位     ENABLE, DISABLE
   46   1          SPI_InitStructure.SPI_Enable    = ENABLE;       //SPI启动    ENABLE, DISABLE
   47   1        SPI_Init(&SPI_InitStructure);
   48   1        NVIC_SPI_Init(ENABLE,Priority_3);   //中断使能, ENABLE/DISABLE; 优先级(低到高) Priority_0,Priority_1,Prio
             -rity_2,Priority_3
   49   1        
   50   1      }
