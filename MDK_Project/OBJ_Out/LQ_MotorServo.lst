  263   2          if (KEY_Read(KEY0) == 0)            // ∞¥œ¬KEY0º¸£¨’ºø’±»º–°
  264   2          {
  265   3          if (duty > -3614)               // ¬˙’ºø’±»Œ™3614 @45.1584 MHz÷˜∆µ MAIN_Fosc/12500
  266   3              duty -= 50;
  267   3          }
  268   2          if (KEY_Read(KEY2) == 0)            // ∞¥œ¬KEY2º¸£¨’ºø’±»º”¥Û
  269   2          {
  270   3          if (duty <3614)
  271   3              duty += 50;
  272   3          }
  273   2          if (KEY_Read(KEY1) == 0)            // ∞¥œ¬KEY1º¸£¨’ºø’±»÷–÷µ
  274   2          {
  275   3            duty = 50;
  276   3          }
  277   2      
  278   2      
  279   2          Motor_Ctrl(duty,duty);
  280   2      
  281   2          sprintf(txt, "PWM: %05d;", duty);
  282   2          OLED_P6x8Str(0, 5, txt);      // ◊÷∑˚¥Æœ‘ æ
  283   2          UART1_PutStr(txt);
  284   2      
  285   2          LED_Ctrl(LED0, RVS);          // µÁ∆Ω∑≠◊™,LED…¡À∏
  286   2          delay_ms(100);                // —” ±µ»¥˝
  287   2        }
  288   1      
  289   1      }
