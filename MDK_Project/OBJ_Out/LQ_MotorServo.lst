               /*********************************************************************************
                * ∫Ø  ˝ √˚£∫void Motor_Ctrl(int16 Motor1, int16 Motor2)
                * π¶    ƒİ£∫7971À´¬∑µÁª˙øÿ÷∆∫Ø ˝
                * ≤Œ  ˝ ÷µ£∫Motor1£∫µÁª˙1’ºø’±»£ªMotor2£∫µÁª˙2’ºø’±»
                * ∑µ ªÿ ÷µ£∫ŒŞ
                * ◊˜    ’ş£∫LQ008
                * ◊Ó∫Û∏¸–¬£∫2024ƒÍ11‘¬17»’
                * »Ìº˛∞Ê±æ£∫V1.0
                * µ˜”√æŸ¿˝£∫MotorCtrl (1000,-2000); //¡Ω∏ˆµÁª˙“ª’˝“ª∑¥◊™∂Ø
                **********************************************************************************/
               void Motor_Ctrl (int16 Motor1,int16 Motor2)
               {
                 if (Motor1 < 0)
                 {
                     Motor1=0-Motor1;
                     UpdatePwmCh(PWM5, 0);
                     UpdatePwmCh(PWM6, Motor1);
                 }
                 else
                 {
                     UpdatePwmCh(PWM5, Motor1);
                     UpdatePwmCh(PWM6, 0);
                 }
               
                 if (Motor2 < 0)
                 {
                     Motor2=0-Motor2;
                     UpdatePwmCh(PWM7, 0);
                     UpdatePwmCh(PWM8, Motor1);
                 }
